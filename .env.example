# Use 5001 on macOS: port 5000 is often taken by AirPlay Receiver (wrong HTTP responses / EADDRINUSE).
PORT=5001
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Comma-separated browser origins for CORS. Use * for local dev (React Native does not rely on browser CORS).
# Medical POS Reactjs (Vite) uses port 8082 by default — include that origin when not using *.
ALLOWED_ORIGINS=http://localhost:8082,http://localhost:5173,http://localhost:5174,http://localhost:8081
NODE_ENV=development

# SuperAdmin app calls /api/v1/medical/* on this server. Tokens are issued by the school Supabase project;
# validate them with the school (ops) project keys — never reuse Medical POS service role for this.
SCHOOL_OPS_SUPABASE_URL=
SCHOOL_OPS_SUPABASE_ANON_KEY=
SCHOOL_OPS_SUPABASE_SERVICE_ROLE_KEY=
